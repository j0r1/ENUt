# the standard variables don't make sense for an uninstalled copy
prefix=
exec_prefix=
libdir=${pcfiledir}/..
includedir=${pcfiledir}/..

Name: ENUt Uninstalled
Description: EDM Network Utilities, Not Installed
Version: @VERSION@
Requires:
Libs: ${libdir}/src/libenut.la @NUTLINKLIBS@
Cflags: -I${includedir}/src @NUTINCLUDES@
